{
  "name": "web-final-backend",
  "version": "1.0.0",
  "description": "Web Final Project - Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon ./src/server.ts",
    "build": "tsc",
    "start": "node ./dist/server.js",
    "test": "tsc && jest --coverage --runInBand --detectOpenHandles --forceExit",
    "test:auth": "tsc && jest --runInBand --detectOpenHandles --forceExit src/tests/auth.test.ts",
    "test:post": "tsc && jest --runInBand --detectOpenHandles --forceExit src/tests/post.test.ts",
    "test:comment": "tsc && jest --runInBand --detectOpenHandles --forceExit src/tests/comment.test.ts",
    "test:user": "tsc && jest --runInBand --detectOpenHandles --forceExit src/tests/user.test.ts"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.9.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.17.10",
    "@types/supertest": "^2.0.16",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
